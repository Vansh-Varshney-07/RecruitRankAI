FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY recruit_ai ./recruit_ai
COPY data/raw/jobs ./data/raw/jobs
COPY data/redrob/sample_candidates.json ./data/redrob/sample_candidates.json

EXPOSE 8000

CMD ["uvicorn", "recruit_ai.api.server:app", "--host", "0.0.0.0", "--port", "8000"]
